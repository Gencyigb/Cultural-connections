extends layouts/layout.pug

block content
  // HERO SECTION
  .hero
    .hero-content
      h1 Discover and share cultures around the world
      p Explore traditions, recipes, languages and customs shared by real people

      .hero-buttons
        a.btn.primary(href="/categories") Start Exploring
        a.btn.secondary(href="/users") Create Account

  // FEATURED CULTURES SECTION
  .section
    h2.section-title Featured Cultures

    .culture-grid
      .card
        img(src="https://images.unsplash.com/photo-1604908176997-431e5b9b17c5")
        h3 Middle Eastern Culture
        a.btn.small(href="/posts") View

      .card
        img(src="https://upload.wikimedia.org/wikipedia/en/a/ae/Flag_of_the_United_Kingdom.svg")
        h3 British Culture
        a.btn.small(href="/posts") View

      .card
        img(src="https://images.unsplash.com/photo-1547981609-4b6bfe67ca0b")
        h3 Asian Culture
        a.btn.small(href="/posts") View

      .card
        img(src="https://images.unsplash.com/photo-1517260911205-8c2b5c3c5b4c")
        h3 Caribbean Culture
        a.btn.small(href="/posts") View

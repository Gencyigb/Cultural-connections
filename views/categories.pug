extends layouts/layout.pug

block content
  .categories-page
    h1.page-title Browse Categories
    
    // Main Categories Section
    section.categories-grid
      h2.section-title Topics
      
      .category-cards
        each category in categories
          .category-card
            .category-icon
              if category.name === 'Food'
                span 🍲
              else if category.name === 'Languages'
                span 🗣️
              else if category.name === 'Traditions'
                span 🎎
              else if category.name === 'Festivals'
                span 🎉
              else
                span 📚
            h3.category-name= category.name
            p.category-count #{category.count} posts
            a(href=`/posts?category=${category.name.toLowerCase()}`) Browse →
    
    // Countries Section - WITH FLAGS
    section.countries-section
      h2.section-title Countries
      .country-list
        each country in countries
          .country-item
            if country.flag && country.flag.startsWith('http')
              img(src=country.flag, alt=country.name, class="country-flag-small")
            else
              span.country-emoji= country.flag
            a(href=`/posts?country=${country.name}`)
              span.country-name= country.name
              span.post-count (#{country.postCount} posts)